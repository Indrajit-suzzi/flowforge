# Environment variables for FlowForge backend.
# See the root .env.example for a complete list with docs.
#
#   cp ../.env.example .env
#
PORT=3000
MAX_CONCURRENT_SESSIONS=3
MONGO_URI=mongodb://127.0.0.1:27017/flowforge
JWT_SECRET=change-this-to-a-random-secret-in-production
NODE_ENV=development
LOG_LEVEL=debug

# Google authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub authentication
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth redirect targets
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# WhatsApp OTP (whatsapp-web.js — free, uses WhatsApp Web)
# WA_SESSION_PATH=./wa-sessions

# Production
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# TRUST_PROXY=1

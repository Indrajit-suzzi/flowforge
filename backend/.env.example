# Environment variables for FlowForge backend.
# See the root .env.example for a complete list with docs.
#
#   cp ../.env.example .env
#
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/flowforge
JWT_SECRET=change-this-to-a-random-secret-in-production
NODE_ENV=development
LOG_LEVEL=debug

# Clerk authentication (optional — both required for Clerk mode)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Production
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# TRUST_PROXY=1

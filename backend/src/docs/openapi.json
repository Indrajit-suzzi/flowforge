{
  "openapi": "3.0.3",
  "info": {
    "title": "FlowForge CMS API",
    "version": "1.0.0",
    "description": "Multi-tenant headless CMS API. Manage content types, entries, media, webhooks, and more.",
    "contact": { "name": "FlowForge" },
    "license": { "name": "MIT" }
  },
  "servers": [
    { "url": "/api/v1", "description": "API v1" }
  ],
  "security": [
    { "bearerAuth": [] },
    { "apiKeyAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token from /api/v1/auth/login or Clerk session token"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key created in the dashboard"
      }
    },
    "schemas": {
      "ContentType": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "fields": { "type": "array", "items": { "$ref": "#/components/schemas/FieldDefinition" } },
          "locales": { "type": "array", "items": { "type": "string" } },
          "cacheTTL": { "type": "integer" },
          "workflowEnabled": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "FieldDefinition": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["String", "Number", "Date", "Boolean", "RichText", "Reference"] },
          "required": { "type": "boolean" },
          "localizable": { "type": "boolean" },
          "refContentType": { "type": "string" },
          "defaultValue": { "type": "string" }
        }
      },
      "Entry": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "tenantId": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "published", "scheduled"] },
          "publishedAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Media": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "mimeType": { "type": "string" },
          "size": { "type": "integer" },
          "url": { "type": "string" },
          "type": { "type": "string", "enum": ["image", "document", "video", "audio", "other"] }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "tags": ["System"],
        "security": [],
        "responses": {
          "200": {
            "description": "Server health status",
            "content": { "application/json": { "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "string" },
                "version": { "type": "string" },
                "uptime": { "type": "integer" },
                "node": { "type": "string" },
                "db": { "type": "string" },
                "memory": { "type": "object" }
              }
            }}}
          }
        }
      }
    },
    "/sitemap.xml": {
      "get": {
        "summary": "Generate sitemap",
        "tags": ["System"],
        "parameters": [
          { "name": "tenant", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "XML sitemap" }
        }
      }
    },
    "/content-types": {
      "get": {
        "summary": "List all content types",
        "tags": ["Content Types"],
        "responses": {
          "200": { "description": "Array of content types", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ContentType" } } } } }
        }
      },
      "post": {
        "summary": "Create a content type",
        "tags": ["Content Types"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContentType" } } } },
        "responses": {
          "201": { "description": "Created content type" },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/content-types/{id}": {
      "get": {
        "summary": "Get content type by ID",
        "tags": ["Content Types"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Content type" }, "404": { "description": "Not found" } }
      },
      "put": {
        "summary": "Update content type",
        "tags": ["Content Types"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated content type" } }
      },
      "delete": {
        "summary": "Delete content type",
        "tags": ["Content Types"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/content-types/templates": {
      "get": {
        "summary": "List content type templates",
        "tags": ["Content Types"],
        "security": [],
        "responses": { "200": { "description": "Array of templates" } }
      }
    },
    "/content-types/from-template": {
      "post": {
        "summary": "Create from template",
        "tags": ["Content Types"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "templateSlug": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Created content type" } }
      }
    },
    "/dynamic/{modelName}": {
      "get": {
        "summary": "List entries for a content type",
        "tags": ["Dynamic Content"],
        "parameters": [
          { "name": "modelName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "published", "scheduled"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "locale", "in": "query", "schema": { "type": "string" } },
          { "name": "tag", "in": "query", "schema": { "type": "string" } },
          { "name": "q", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Paginated entries" } }
      },
      "post": {
        "summary": "Create an entry",
        "tags": ["Dynamic Content"],
        "parameters": [{ "name": "modelName", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "201": { "description": "Created entry" } }
      }
    },
    "/dynamic/{modelName}/{id}": {
      "get": {
        "summary": "Get entry by ID",
        "tags": ["Dynamic Content"],
        "parameters": [
          { "name": "modelName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entry" }, "404": { "description": "Not found" } }
      },
      "put": {
        "summary": "Update entry",
        "tags": ["Dynamic Content"],
        "parameters": [
          { "name": "modelName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Updated entry" } }
      },
      "delete": {
        "summary": "Delete entry",
        "tags": ["Dynamic Content"],
        "parameters": [
          { "name": "modelName", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/media": {
      "get": {
        "summary": "List media",
        "tags": ["Media"],
        "parameters": [
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["image", "document", "video", "audio", "other"] } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Paginated media", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Media" } } } } } }
      },
      "post": {
        "summary": "Upload media",
        "tags": ["Media"],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } },
        "responses": { "201": { "description": "Uploaded media" } }
      }
    },
    "/media/{id}": {
      "delete": {
        "summary": "Delete media",
        "tags": ["Media"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/webhooks": {
      "get": {
        "summary": "List webhooks",
        "tags": ["Webhooks"],
        "responses": { "200": { "description": "Array of webhooks" } }
      },
      "post": {
        "summary": "Create webhook",
        "tags": ["Webhooks"],
        "responses": { "201": { "description": "Created webhook" } }
      }
    },
    "/webhooks/{id}": {
      "put": { "summary": "Update webhook", "tags": ["Webhooks"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Updated" } } },
      "delete": { "summary": "Delete webhook", "tags": ["Webhooks"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Deleted" } } }
    },
    "/webhooks/{id}/test": {
      "post": { "summary": "Test webhook delivery", "tags": ["Webhooks"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Test result" } } }
    },
    "/webhooks/{id}/logs": {
      "get": { "summary": "Get webhook delivery logs", "tags": ["Webhooks"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Paginated logs" } } }
    },
    "/webhooks/{id}/rotate-secret": {
      "post": { "summary": "Rotate webhook secret", "tags": ["Webhooks"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "New secret" } } }
    },
    "/graphql": {
      "post": {
        "summary": "GraphQL endpoint",
        "tags": ["GraphQL"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "query": { "type": "string" }, "variables": { "type": "object" } } } } } },
        "responses": { "200": { "description": "GraphQL response" } }
      }
    },
    "/search": {
      "get": {
        "summary": "Full-text search across entries",
        "tags": ["Search"],
        "parameters": [{ "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Search results" } }
      }
    },
    "/api-keys": {
      "get": { "summary": "List API keys", "tags": ["API Keys"], "responses": { "200": { "description": "Array of API keys" } } },
      "post": { "summary": "Create API key", "tags": ["API Keys"], "responses": { "201": { "description": "Created API key" } } }
    },
    "/roles": {
      "get": { "summary": "List roles", "tags": ["Roles"], "responses": { "200": { "description": "Array of roles" } } },
      "post": { "summary": "Create role", "tags": ["Roles"], "responses": { "201": { "description": "Created role" } } }
    },
    "/forms": {
      "get": { "summary": "List forms", "tags": ["Forms"], "responses": { "200": { "description": "Array of forms" } } },
      "post": { "summary": "Create form", "tags": ["Forms"], "responses": { "201": { "description": "Created form" } } }
    },
    "/forms/{id}/submissions": {
      "get": { "summary": "List form submissions", "tags": ["Forms"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Paginated submissions" } } }
    },
    "/tags": {
      "get": { "summary": "List tags", "tags": ["Tags"], "responses": { "200": { "description": "Array of tags" } } },
      "post": { "summary": "Create tag", "tags": ["Tags"], "responses": { "201": { "description": "Created tag" } } }
    },
    "/users": {
      "get": { "summary": "List users", "tags": ["Users"], "responses": { "200": { "description": "Array of users" } } }
    },
    "/audit-logs": {
      "get": { "summary": "List audit logs", "tags": ["Audit Logs"], "parameters": [{ "name": "page", "in": "query", "schema": { "type": "integer" } }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }], "responses": { "200": { "description": "Paginated audit logs" } } }
    },
    "/analytics": {
      "get": { "summary": "Get analytics", "tags": ["Analytics"], "responses": { "200": { "description": "Analytics data" } } }
    },
    "/calendar": {
      "get": { "summary": "Get content calendar", "tags": ["Calendar"], "parameters": [{ "name": "year", "in": "query", "schema": { "type": "integer" } }, { "name": "month", "in": "query", "schema": { "type": "integer" } }], "responses": { "200": { "description": "Calendar data" } } }
    },
    "/stats/export": {
      "get": { "summary": "Export all content as JSON", "tags": ["Stats"], "responses": { "200": { "description": "JSON export" } } }
    },
    "/theme": {
      "get": { "summary": "Get tenant theme", "tags": ["Theme"], "responses": { "200": { "description": "Theme settings" } } },
      "put": { "summary": "Update tenant theme", "tags": ["Theme"], "responses": { "200": { "description": "Updated theme" } } }
    },
    "/theme.css": {
      "get": { "summary": "Get theme CSS", "tags": ["Theme"], "security": [], "responses": { "200": { "description": "CSS stylesheet", "content": { "text/css": { "schema": { "type": "string" } } } } } }
    }
  },
  "tags": [
    { "name": "System", "description": "System endpoints" },
    { "name": "Content Types", "description": "Manage content type schemas" },
    { "name": "Dynamic Content", "description": "CRUD operations on dynamic entries" },
    { "name": "Media", "description": "File uploads and management" },
    { "name": "Webhooks", "description": "Webhook configuration and logs" },
    { "name": "GraphQL", "description": "GraphQL query interface" },
    { "name": "Search", "description": "Full-text search" },
    { "name": "API Keys", "description": "API key management" },
    { "name": "Roles", "description": "Role-based access control" },
    { "name": "Forms", "description": "Form builder and submissions" },
    { "name": "Tags", "description": "Content tagging" },
    { "name": "Users", "description": "User management" },
    { "name": "Audit Logs", "description": "Audit trail" },
    { "name": "Analytics", "description": "Usage analytics" },
    { "name": "Calendar", "description": "Content publishing calendar" },
    { "name": "Theme", "description": "Branding and theming" }
  ]
}

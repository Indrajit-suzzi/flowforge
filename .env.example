# =============================================
# FlowForge — Environment Variables
# =============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
#
# For development, see each section's defaults.
# =============================================

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── Database ──────────────────────────────────
# Required: MongoDB connection string
MONGO_URI=mongodb://localhost:27017/flowforge

# ── Authentication ────────────────────────────
# Required: JWT secret key used for app sessions
JWT_SECRET=change-this-to-a-random-secret-in-production

# Google OAuth credentials.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# GitHub OAuth credentials.
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# OAuth redirect targets.
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults: http://localhost:5173,http://localhost:3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Proxy ─────────────────────────────────────
# Express trust proxy setting. Set to 1 behind a
# reverse proxy (e.g. Docker, nginx).
# TRUST_PROXY=1

# ── Frontend (Vite) ───────────────────────────
# Required: Google OAuth client ID for the frontend.
# VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional: API base URL (empty = relative/proxied by Vite).
# VITE_API_URL=http://localhost:3000

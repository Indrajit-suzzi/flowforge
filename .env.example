# =============================================
# FlowForge — Environment Variables
# =============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
#
# For development, see each section's defaults.
# =============================================

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── Database ──────────────────────────────────
# Required: MongoDB connection string
MONGO_URI=mongodb://localhost:27017/flowforge

# ── Authentication ────────────────────────────
# Required (unless using Clerk): JWT secret key
JWT_SECRET=change-this-to-a-random-secret-in-production

# Optional: Clerk credentials for Clerk-based auth.
# Both must be set together to enable Clerk mode.
# When omitted, the app falls back to JWT auth.
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults: http://localhost:5173,http://localhost:3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Proxy ─────────────────────────────────────
# Express trust proxy setting. Set to 1 behind a
# reverse proxy (e.g. Docker, nginx).
# TRUST_PROXY=1

# ── Frontend (Vite) ───────────────────────────
# Required: Clerk publishable key for the frontend.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: API base URL (empty = relative/proxied by Vite).
# VITE_API_URL=http://localhost:3000
